# ============================================
# NEXOCRM - CONFIGURACIÓN
# ============================================
# Copiá este archivo como .env y completá los valores
# cp .env.example .env

# Puerto del servidor (Railway lo asigna automáticamente)
PORT=3000

# URL pública del servidor (se completa después del deploy)
# Ejemplo: https://tu-app.up.railway.app
BASE_URL=http://localhost:3000

# ============================================
# ANTHROPIC (Claude IA) - OBLIGATORIO
# ============================================
# Obtener en: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx

# ============================================
# META (WhatsApp + Instagram + Facebook)
# ============================================
# Obtener en: https://developers.facebook.com/
META_APP_ID=
META_APP_SECRET=
META_VERIFY_TOKEN=mi_token_secreto_123

# WhatsApp - Token de acceso permanente (System User Token)
WHATSAPP_TOKEN=

# IDs de las 3 líneas de WhatsApp (se obtienen al registrar los números)
WHATSAPP_PHONE_ID_1=
WHATSAPP_PHONE_ID_2=
WHATSAPP_PHONE_ID_3=

# Instagram - Token de acceso de página
INSTAGRAM_TOKEN=

# Facebook - Token de acceso de página  
FACEBOOK_PAGE_TOKEN=
FACEBOOK_PAGE_ID=

# ============================================
# EMAIL (SendGrid)
# ============================================
# Obtener en: https://app.sendgrid.com/
SENDGRID_API_KEY=
EMAIL_FROM=soporte@tuempresa.com

# ============================================
# AUTENTICACIÓN DEL CRM
# ============================================
# Contraseña para acceder al panel (cambiar por una segura)
ADMIN_PASSWORD=admin123

# ============================================
# CONFIGURACIÓN DE LA EMPRESA
# ============================================
COMPANY_NAME=Mi Empresa
